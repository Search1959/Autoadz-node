# AutoAdz Environment Variables - copy to .env and fill in your values

ANTHROPIC_API_KEY=your_anthropic_api_key_here

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=autoadz_db

NODE_ENV=production
PORT=3000
APP_URL=https://autoadz.in

# Redis (optional — add when upgrading to VPS + PM2 cluster)
# Get free URL from: https://upstash.com → Create Database → Copy REST URL
# REDIS_URL=rediss://default:your_password@your-endpoint.upstash.io:6379
